{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/solucoes/simpli-agent",
      "destination": "/api/seo?route=simpli-agent"
    },
    {
      "source": "/solucoes/simpli-crm",
      "destination": "/api/seo?route=simpli-crm"
    },
    {
      "source": "/solucoes/simpli-estoque",
      "destination": "/api/seo?route=simpli-estoque"
    },
    {
      "source": "/servicos/desenvolvimento-web",
      "destination": "/api/seo?route=servico-desenvolvimento-web"
    },
    {
      "source": "/servicos/agentes-de-ia",
      "destination": "/api/seo?route=servico-agentes-de-ia"
    },
    {
      "source": "/servicos/trafego-pago",
      "destination": "/api/seo?route=servico-trafego-pago"
    },
    {
      "source": "/servicos/consultoria-digital",
      "destination": "/api/seo?route=servico-consultoria-digital"
    },
    {
      "source": "/conteudo",
      "destination": "/api/seo?list=1"
    },
    {
      "source": "/conteudo/",
      "destination": "/api/seo?list=1"
    },
    {
      "source": "/conteudo/:path*",
      "destination": "/api/seo?slug=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/solucoes/simpli-agent/",
      "destination": "/solucoes/simpli-agent",
      "permanent": true
    },
    {
      "source": "/solucoes/simpli-crm/",
      "destination": "/solucoes/simpli-crm",
      "permanent": true
    },
    {
      "source": "/solucoes/simpli-estoque/",
      "destination": "/solucoes/simpli-estoque",
      "permanent": true
    },
    {
      "source": "/servicos/desenvolvimento-web/",
      "destination": "/servicos/desenvolvimento-web",
      "permanent": true
    },
    {
      "source": "/servicos/agentes-de-ia/",
      "destination": "/servicos/agentes-de-ia",
      "permanent": true
    },
    {
      "source": "/servicos/trafego-pago/",
      "destination": "/servicos/trafego-pago",
      "permanent": true
    },
    {
      "source": "/servicos/consultoria-digital/",
      "destination": "/servicos/consultoria-digital",
      "permanent": true
    }
  ]
}
